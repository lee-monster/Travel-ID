# =====================================================
# Travel-ID Environment Variables
# =====================================================
# Copy this file to .env.local for local development.
# For production, set these in the Vercel dashboard
# (Project Settings → Environment Variables).
# =====================================================

# --- Site URL (used in OG tags, sitemap, share links) ---
# Set to your canonical origin once a domain is decided.
# If unset, falls back to the request host (works for *.vercel.app previews).
PUBLIC_SITE_URL=https://travel-id.vercel.app

# --- Supabase (auth + database) ---
# Travel-ID co-tenants the existing TravelKo Supabase project: all its tables
# live in a dedicated `travelid` PostgreSQL schema. Reuse the SAME values you
# already use for TravelKo (Project Settings → API).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Schema name for Travel-ID tables. Override only if you also rename it in the
# 0001_init.sql migration. Must be added to Project Settings → API → Exposed
# schemas (alongside `public`).
SUPABASE_SCHEMA=travelid

# --- Google Maps ---
# Frontend Maps JS API key — restrict to HTTP referrers (your domain only).
# Required APIs: Maps JavaScript API, Places API.
GOOGLE_MAPS_API_KEY=

# Server-side Geocoding API key — no referrer restriction, IP-restricted instead.
# Required API: Geocoding API.
GOOGLE_GEOCODING_API_KEY=

# --- Google OAuth (frontend client ID for Google Identity Services button) ---
# Create at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include your Vercel URL + chosen domain.
# Also enable Google as an auth provider in Supabase: Auth → Providers → Google
# (paste the same Client ID + Client Secret).
GOOGLE_CLIENT_ID=

# --- Gemini AI Planner ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- (Optional) Notion → Supabase migration script ---
# Only needed if you want to import the 36 spots that lived in Notion.
# Run once: node -r dotenv/config scripts/migrate-notion-to-supabase.js \
#   dotenv_config_path=.env.local
NOTION_TOKEN_TRAVEL=
NOTION_DB_TRAVEL=10e3dd6ce89841e98a211c5ac4fd2449
