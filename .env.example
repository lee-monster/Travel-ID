# =====================================================
# Travel-ID Environment Variables
# =====================================================
# Copy this file to .env.local for local development.
# For production, set these in the Vercel dashboard
# (Project Settings → Environment Variables).
# =====================================================

# --- Site URL (used in OG tags, sitemap, share links) ---
# Set to your canonical origin once a domain is decided.
# If unset, falls back to the request host (works for *.vercel.app previews).
PUBLIC_SITE_URL=https://travel-id.vercel.app

# --- Notion (backend DB) ---
# Get a token from https://www.notion.so/my-integrations
# Then share the parent page "Travel-ID" with the integration.
NOTION_TOKEN_TRAVEL=

# Spots DB (created via Notion MCP on bootstrap)
NOTION_DB_TRAVEL=10e3dd6ce89841e98a211c5ac4fd2449

# Users DB (created via Notion MCP on bootstrap)
NOTION_DB_USERS=d4a523eeebae48eb868a61259ec1d98d

# SharedPlans DB (created via Notion MCP on bootstrap)
NOTION_DB_SHARED_PLANS=43e9ab1e470d4894a708e8a6a2f513d5

# --- Google Maps ---
# Frontend Maps JS API key — restrict to HTTP referrers (your domain only).
# Required APIs: Maps JavaScript API, Places API.
GOOGLE_MAPS_API_KEY=

# Server-side Geocoding API key — no referrer restriction, IP-restricted instead.
# Required API: Geocoding API.
GOOGLE_GEOCODING_API_KEY=

# --- Google OAuth ---
# Create at https://console.cloud.google.com/apis/credentials
# Add your Vercel URL + chosen domain to Authorized JavaScript origins.
GOOGLE_CLIENT_ID=

# --- Auth (JWT) ---
# 64+ random chars. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# --- Gemini AI Planner ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
